{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "github>dszakallas/renovate-config//default.json5",
    "docker:enableMajor",
    ":automergeBranch",
    ":skipStatusChecks",
  ],

  schedule: ["* 6-12 30 * *"],
  timezone: "Europe/Prague",
  labels: ["dep", "autofix"],

  npm: {
    enabled: true,
    fileMatch: ["(^|/)package\\.json$"],
  },
  gomod: {
    enabled: true,
  },
  packageRules: [
    {
      matchManagers: ["gomod"],
      semanticCommitScope: "deps",
      addLabels: ["dep/source:go"],
    },
    {
      matchManagers: ["npm"],
      semanticCommitScope: "deps",
      addLabels: ["dep/source:npm"],
    },
  ],
}
